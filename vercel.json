{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/assets/images/(.*)",
      "dest": "/public/assets/images/$1"
    },
    {
      "src": "/assets/images/logo(.*)",
      "dest": "/public/assets/images/logo/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ]
}